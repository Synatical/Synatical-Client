# C++ .gitignore - General purpose for C, C++ projects

# Compiled object files, static and dynamic libs
*.o
*.obj
*.lo
*.la
*.al
*.libs

# Static and shared libraries
*.lib
*.a
*.so
*.so.*
*.dylib
*.dll

# Executables
*.exe
*.out
*.app
a.out

# Build directories
/build/
/build-*/
/bin/
/obj/
/lib/
/lib64/
/dist/
/out/
/Release/
/Debug/
/cmake-build-*/

# CMake artifacts
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
Makefile

# Visual Studio
.vs/
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates
*.sdf
*.ipch
*.opensdf
*.ncb

# JetBrains (CLion, IntelliJ)
.idea/
cmake-build-debug/

# VS Code
.vscode/

# Qt Creator
*.pro.user
*.qmake.stash
*.qrc.dep
*.moc
moc_*.cpp

# Xcode
*.xcworkspace
*.xcuserdata
*.xcuserstate
*.xcodeproj/project.xcworkspace/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xccheckout
*.xcscmblueprint
*.moved-aside
*.dSYM/

# Autotools
*.deps
.libs/

# Autogenerated dependency files
*.d

# Coverage and profiling
coverage/
*.gcno
*.gcda
*.gcov
*.prof

# Debug symbols, intermediate files
*.pdb
*.ilk
*.idb
*.ipdb

# Package managers and build helpers
conanbuildinfo.*
conaninfo.txt
conan.lock
vcpkg_installed/
.vcpkg/

# Ccache
.ccache/

# Misc
*~
*.swp
*.lock
*.log
*.tmp
*.temp
*.bak
*.orig

# Tags and editor files
tags
TAGS
*.DS_Store

# Generated files/directories
/generated/
**/generated/

# Node / Python build artifacts sometimes present in mixed projects
node_modules/
__pycache__/
*.pyc

# End of file
